varip float tradeEntryPrice = 0
varip string tradeSide = ""
varip bool canSignal = true
varip int trailOffset = 0 
varip float trailPrice = 0
varip bool corShiftLong = false
varip bool corShiftShort = false
varip bool corShiftWait = false
varip bool canDraw = false

if strategy.opentrades > 0
    canSignal := false
else 
    strategy.cancel_all()
    canSignal := true


// Corrective shift
// fib_382 = high_line - channel_range * 0.382
// fib_5 = high_line - channel_range * 0.5
// fib_618 = high_line - channel_range * 0.618

varip bool canDrawCor = false
var int corStartBar = 0
barIndex = bar_index

var bool corBarPassed = false
corBarPassed := corStartBar != 0 and (barIndex - corStartBar >= corShiftBars)

if useCorShift and corShiftWait and tradeSide == "LONG" and close <= (useCorShiftAuto ? fib_382 : tradeEntryPrice * (1- corShiftSize) ) and (close >= tradeEntryPrice* (1 - sl_percent) or corShiftMode == "Move TP/SL")
    corShiftLong := true
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "LONG" and close <= tradeEntryPrice* (1 - sl_percent)  and corShiftMode == "Don't move TP/SL"
    corShiftLong := false
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "LONG" and close >= tradeEntryPrice * (1+ tp1_percent) 
    corShiftLong := false
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "LONG" and useCorShiftBars and corBarPassed 
    corShiftLong := false
    corShiftWait := false
    canDrawCor := false


if useCorShift and corShiftWait and tradeSide == "SHORT" and close >= (useCorShiftAuto ? fib_618 : tradeEntryPrice * (1+ corShiftSize)) and (close <= tradeEntryPrice* (1 + sl_percent) or corShiftMode == "Move TP/SL")
    corShiftShort := true
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "SHORT" and close >= tradeEntryPrice* (1+ sl_percent) and corShiftMode == "Don't move TP/SL"
    corShiftShort := false
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "SHORT" and close <= tradeEntryPrice * (1- tp1_percent) 
    corShiftShort := false
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "SHORT" and useCorShiftBars and corBarPassed
    corShiftLong := false
    corShiftWait := false
    canDrawCor := false

// plot(canSignal ? 1 : 0)
// plot(corShiftLong ? 1 : 0)
// plot(corShiftShort ? 1 : 0)

// Volume calculating
var bool volAnomaly = false

var bool volVWAPLong = false 
var bool volVWAPShort = false

// var bool volOBVLong = false
// var bool volOBVShort = false
    // Anomaly
if useVolAnomaly and volAnomalyReverse == false 
    averageVolume = ta.sma(volume, volAnomalySMALen)
    volAnomaly := volume < (averageVolume*volAnomalyMult)
else if useVolAnomaly and volAnomalyReverse
    averageVolume = ta.sma(volume, volAnomalySMALen)
    volAnomaly := volume > (averageVolume*volAnomalyMult)

    // OBV
// if useVolOBV
//     obvValue = ta.obv
//     volOBVShort := ta.falling(obvValue, volOBVLen) and ta.rising(close, volOBVLen)
//     volOBVLong := ta.rising(obvValue, volOBVLen) and ta.falling(close, volOBVLen)

    // VWAP
if useVolVWAP
    vwapValue = ta.vwap(close)
    volVWAPLong := ta.crossover(close, vwapValue)  // Покупка при пробое VWAP снизу вверх
    volVWAPShort := ta.crossunder(close, vwapValue)  // Продажа при пробое VWAP сверху вниз

// EMA calculationg
var bool longEMA = false
var bool shortEMA = false

fastAverage = ta.ema(averageData, fastLength)
slowAverage = ta.ema(averageData, slowLength)
longAverage = ta.ema(averageData, longLength)

if use3EMA
    longEMA := useEMA == false or (close > fastAverage and fastAverage > slowAverage and slowAverage > longAverage)
    shortEMA := useEMA == false or (close < fastAverage and fastAverage < slowAverage and slowAverage < longAverage)
else
    longEMA := useEMA == false or (close > fastAverage and fastAverage > slowAverage)
    shortEMA := useEMA == false or (close < fastAverage and fastAverage < slowAverage)

// plot(useEMA ? fastAverage : na, color = color.blue, linewidth = 1, title = "Short-term average")
// plot(useEMA ? slowAverage : na, color = color.purple, linewidth = 1, title = "Middle-term average")
// plot(useEMA and use3EMA ? longAverage : na, color = color.maroon, linewidth = 1, title = "Long-term average")

// RSI
// "Overbought-buy, oversold-sell","Overbought-sell, oversold-buy"
varip bool longRSI = true
varip bool longRSIChange = false
varip bool shortRSI = true
varip bool shortRSIChange = false
varip float currentRSI = na

currentRSI := ta.rsi(close, len)
currentRSIAddl = useTFRSI ? request.security(syminfo.tickerid, TFRSI, ta.rsi(close, TFRSILen)) : na

if useTFRSI
    if modeRSI == "Overbought-buy, oversold-sell" and useRSI == true
        longRSI := (currentRSI > overbought and currentRSIAddl > overbought) or useRSI == false
        shortRSI := (currentRSI < oversold and currentRSIAddl < oversold) or useRSI == false
    else if modeRSI == "Overbought-sell, oversold-buy" and useRSI == true
        if (currentRSI < oversold and currentRSIAddl < oversold) or longRSIChange
            longRSI := true
            shortRSI := false
            longRSIChange := true
            shortRSIChange := false
        
        if (currentRSI >= 50 and currentRSIAddl >= 50)
            longRSI := false
            longRSIChange := false

        if (currentRSI > overbought and currentRSIAddl > overbought) or shortRSIChange
            shortRSI :=  true
            longRSI := false
            longRSIChange := false
            shortRSIChange := true
        
        if (currentRSI <= 50 and currentRSIAddl <= 50)
            shortRSI := false
            shortRSIChange := false
else 
    if modeRSI == "Overbought-buy, oversold-sell" and useRSI == true
        longRSI := currentRSI > overbought or useRSI == false
        shortRSI := currentRSI < oversold or useRSI == false
    else if modeRSI == "Overbought-sell, oversold-buy" and useRSI == true
        if currentRSI < oversold or longRSIChange
            longRSI := true
            shortRSI := false
            longRSIChange := true
            shortRSIChange := false
        
        if currentRSI >= 50
            longRSI := false
            longRSIChange := false

        if currentRSI > overbought or shortRSIChange
            shortRSI :=  true
            longRSI := false
            longRSIChange := false
            shortRSIChange := true
        
        if currentRSI <= 50
            shortRSI := false
            shortRSIChange := false
// plot(longRSI ? 1 : 0)
// plot(shortRSI ? 1 : 0)
// plot(currentRSI)

// Max profit and drawdown
var int rowLossCount = 0

if strategy.losstrades > strategy.losstrades[1]
    rowLossCount += 1

if strategy.wintrades > strategy.wintrades[1]
    rowLossCount := 0

if useMaxRowLoss and rowLossCount == maxRowLoss
    canSignal := false
    corShiftLong := false
    corShiftShort := false
    alert("Max number of loss trades in a row is detected! Please, restart the strategy")    

// plot(canSignal ? 1 : 0)
// plot(rowLossCount)
// plot(strategy.losstrades)
// plot(strategy.losstrades[1])

plotshape(canLongNew and na(trade) and canSignal and strDirection != "only short" and longRSI and longEMA and useCorShift ? imba_trend_line : na, title="Long", style=shape.arrowup, location=location.belowbar, color=color.green, size=size.small)
plotshape(canShortNew and na(trade) and canSignal and strDirection != "only long" and shortRSI and shortEMA and useCorShift ? imba_trend_line : na, title="Short", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.small)


// Position mode
if strDirection == "only long"
    can_short := false 
    canShortNew := false
else if strDirection == "only short"
    can_long := false
    canLongNew := false

var float atrVal = 0
var float tradeTP1Limit = 0
var float tradeTP2Limit = 0
var float tradeTP3Limit = 0
var float tradeTP4Limit = 0
var float tradeTP1Size = 0
var float tradeTP2Size = 0
var float tradeTP3Size = 0
var float tradeTP4Size = 0
var float tradeSL = 0
var float tradeTrailPrice = 0
// ATR
if atrAutoActive
    atrVal := ta.atr(atrLength)




// Entries
if (canLongNew and na(trade) and canSignal and strDirection != "only short" and longRSI and longEMA and (useVolAnomaly == false or volAnomaly) and (useVolVWAP == false or volVWAPLong)) or (tradeSide == "LONG" and corShiftLong and corShiftShort == false)
    tradeSide := "LONG"
    canDrawCor := false
    
    if useCorShift and corShiftLong == false
        tradeEntryPrice := close
        if corShiftMode == "Don't move TP/SL"
            canDraw := true
        corShiftWait := true
        corShiftShort := false
        corStartBar := bar_index

    else if corShiftLong or useCorShift == false
        strategy.close("Enter Short")
        strategy.entry("Enter Long", strategy.long)

        if useCorShift == false or (useCorShift and corShiftMode == "Move TP/SL")
            canDraw := true
            tradeEntryPrice := close
        
        corShiftLong := false
        canSignal := false
        // tradeEntryPrice := close
        tradeTP1Limit := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultTP) : tradeEntryPrice* (1 + tp1_percent)
        tradeTP1Size := tp1_percent_fix * 100
        tradeTP2Limit := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultTP * 2) : tradeEntryPrice* (1 + tp2_percent_fix)
        tradeTP2Size := tp2_percent_fix * 100
        tradeTP3Limit := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultTP * 3) : tradeEntryPrice* (1 + tp3_percent)
        tradeTP3Size := tp3_percent_fix * 100
        tradeSL := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultSL) : tradeEntryPrice* (1 - sl_percent)
        trailOffset := int((close * (trailPercent / 100)) / syminfo.mintick)
        if trailWithPercent == true
            tradeTrailPrice := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultTrail) : tradeEntryPrice* (1 + trailStartPercent)
        else 
            if trailTP == 0
                tradeTrailPrice := 0
            else if trailTP == 1
                tradeTrailPrice := tradeTP1Limit
            else if trailTP == 2
                tradeTrailPrice := tradeTP2Limit
            // else if trailTP == 3
            //     trailPrice := tradeEntryPrice* (1 + tp3_percent)
        // once TP
        if onceTP 
            strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Long: trail", comment_profit = "Long: TP-1", comment_loss = "Long: stoploss")
        else 
            // Проверка на 0 ордера
            if tp1_percent_fix != 0 and (tp2_percent_fix != 0 or tp3_percent_fix != 0 or tp4_percent_fix != 0) 
                strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP1Size, comment_trailing = "Long: trail", comment_profit = "Long: TP-1", comment_loss = "Long: stoploss")
            else if tp1_percent_fix != 0 and (tp2_percent_fix == 0 and tp3_percent_fix == 0 and tp4_percent_fix == 0)
                strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Long: trail", comment_profit = "Long: TP-1", comment_loss = "Long: stoploss")
            
            if tp2_percent_fix != 0 and (tp3_percent_fix != 0 or tp4_percent_fix != 0)
                strategy.exit("Long TP-2/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP2Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP2Size, comment_trailing = "Long: trail", comment_profit = "Long: TP-2", comment_loss = "Long: stoploss")
            else if tp2_percent_fix != 0 and (tp3_percent_fix == 0 and tp4_percent_fix == 0)
                strategy.exit("Long TP-2/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP2Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Long: trail", comment_profit = "Long: TP-2", comment_loss = "Long: stoploss")
            
            if tp3_percent_fix != 0 and tp4_percent_fix != 0
                strategy.exit("Long TP-3/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP3Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP3Size, comment_trailing = "Long: trail", comment_profit = "Long: TP-3", comment_loss = "Long: stoploss")
            else if tp3_percent_fix != 0 and tp4_percent_fix == 0
                strategy.exit("Long TP-3/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP3Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Long: trail", comment_profit = "Long: TP-3", comment_loss = "Long: stoploss")
            
            // if tp4_percent_fix != 0
            //     strategy.exit("Long TP-4/Trail/SL", from_entry="Enter Long", stop = fixed_stop ? tradeEntryPrice* (1 - sl_percent) : fib_786, limit=tradeEntryPrice* (1 + tp4_percent), trail_price = trailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Long: trail", comment_profit = "Long: TP-4", comment_loss = "Long: stoploss" )

if (canShortNew and na(trade) and canSignal and strDirection != "only long" and shortRSI and shortEMA and (useVolAnomaly == false or volAnomaly) and (useVolVWAP == false or volVWAPShort)) or (tradeSide == "SHORT" and corShiftShort and corShiftLong == false)
    tradeSide := "SHORT"
    canDrawCor := false
    if useCorShift and corShiftShort == false
        tradeEntryPrice := close
        if corShiftMode == "Don't move TP/SL"
            canDraw := true
        corShiftWait := true
        corShiftLong := false
        corStartBar := bar_index
    
    else if corShiftShort or useCorShift == false
        strategy.close("Enter Long")
        strategy.entry("Enter Short", strategy.short)

        if useCorShift == false or (useCorShift and corShiftMode == "Move TP/SL")
            canDraw := true
            tradeEntryPrice := close

        corShiftShort := false
        canSignal := false
        // tradeEntryPrice := close
        tradeTP1Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP) : tradeEntryPrice* (1 - tp1_percent)
        tradeTP1Size := tp1_percent_fix * 100
        tradeTP2Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP * 2) : tradeEntryPrice* (1 - tp2_percent_fix)
        tradeTP2Size := tp2_percent_fix * 100
        tradeTP3Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP * 3) : tradeEntryPrice* (1 - tp3_percent)
        tradeTP3Size := tp3_percent_fix * 100
        tradeSL := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultSL) : tradeEntryPrice* (1 + sl_percent)
        trailOffset := int((close * (trailPercent / 100)) / syminfo.mintick)
        if trailWithPercent == true
            tradeTrailPrice := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTrail) : tradeEntryPrice* (1 - trailStartPercent)
        else 
            if trailTP == 0
                tradeTrailPrice := 0
            else if trailTP == 1
                tradeTrailPrice := tradeTP1Limit
            else if trailTP == 2
                tradeTrailPrice := tradeTP2Limit
            // else if trailTP == 3
            //     trailPrice := tradeEntryPrice* (1 + tp3_percent)
        // once TP
        if onceTP 
            strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Short: trail", comment_profit = "Short: TP-1", comment_loss = "Short: stoploss")
        else 
            // Проверка на 0 ордера
            if tp1_percent_fix != 0 and (tp2_percent_fix != 0 or tp3_percent_fix != 0 or tp4_percent_fix != 0) 
                strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP1Size, comment_trailing = "Short: trail", comment_profit = "Short: TP-1", comment_loss = "Short: stoploss")
            else if tp1_percent_fix != 0 and (tp2_percent_fix == 0 and tp3_percent_fix == 0 and tp4_percent_fix == 0)
                strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Short: trail", comment_profit = "Short: TP-1", comment_loss = "Short: stoploss")
            
            if tp2_percent_fix != 0 and (tp3_percent_fix != 0 or tp4_percent_fix != 0)
                strategy.exit("Long TP-2/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP2Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP2Size, comment_trailing = "Short: trail", comment_profit = "Short: TP-2", comment_loss = "Short: stoploss")
            else if tp2_percent_fix != 0 and (tp3_percent_fix == 0 and tp4_percent_fix == 0)
                strategy.exit("Long TP-2/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP2Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Short: trail", comment_profit = "Short: TP-2", comment_loss = "Short: stoploss")
            
            if tp3_percent_fix != 0 and tp4_percent_fix != 0
                strategy.exit("Long TP-3/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP3Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP3Size, comment_trailing = "Short: trail", comment_profit = "Short: TP-3", comment_loss = "Short: stoploss")
            else if tp3_percent_fix != 0 and tp4_percent_fix == 0
                strategy.exit("Long TP-3/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP3Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Short: trail", comment_profit = "Short: TP-3", comment_loss = "Short: stoploss")
         
// Закомментировать
// plot(canSignal ? 1.0 : 0)
// plot(can_long ? 1.0 : 0)
// plot(na(trade) ? 1.0 : 0)
// plot(tradeEntryPrice)
// plot(math.ceil(trailOffset))


// New lines
var line lineTP1 = na
var line lineTP2 = na
var line lineTP3 = na
var line lineTP4 = na
var line lineSL = na
var line lineTrail = na
var line lineCor = na
var line lineEntry = na
var int startBarIndex = na
var int startBarIndexCor = na
var float priceTP1 = na
var float priceTP2 = na
var float priceTP3 = na
var float priceTP4 = na
var float priceSL = na
var float priceCor = na
varip bool hitTP1 = na
varip bool hitTP2 = na
varip bool hitTP3 = na
// varip bool hitTP4 = na
var bool hitSL = na
varip bool canFill = na
varip float cortradeEntryPrice = na

// Creating lines
if corShiftWait and canDrawCor != true and show_tp_enty_sl
    startBarIndexCor := bar_index
    cortradeEntryPrice := tradeEntryPrice
    priceCor := tradeSide == "LONG" ? (useCorShiftAuto ? fib_382 : cortradeEntryPrice * (1- corShiftSize)) : (useCorShiftAuto ? fib_618 : cortradeEntryPrice * (1+ corShiftSize))
    lineCor := useCorShift and useCorShiftAuto != true ? line.new(x1=startBarIndex, y1=priceCor, x2=bar_index, y2=priceCor, color=color.yellow, style = line.style_dotted, width = 2) : na
    canDrawCor := true

if corShiftWait and canDrawCor
    // Cor
    line.set_xy1(lineCor, startBarIndexCor, priceCor)
    line.set_xy2(lineCor, bar_index + 1, priceCor)


if canDraw
    canDraw := false
    startBarIndex := bar_index

    priceSL  := tradeSide == "LONG" ?  (fixed_stop ? tradeEntryPrice* (1 - sl_percent) : fib_786) : (fixed_stop ? tradeEntryPrice* (1 + sl_percent) : fib_236)
    priceTP1 := tradeSide == "LONG" ?  tradeEntryPrice* (1 + tp1_percent) : tradeEntryPrice* (1 - tp1_percent)
    priceTP2 := tradeSide == "LONG" ?  tradeEntryPrice* (1 + tp2_percent) : tradeEntryPrice* (1 - tp2_percent)
    priceTP3 := tradeSide == "LONG" ?  tradeEntryPrice* (1 + tp3_percent) : tradeEntryPrice* (1 - tp3_percent)
    trailPrice := tradeSide == "LONG" ? tradeEntryPrice* (1 + trailStartPercent) : tradeEntryPrice* (1 - trailStartPercent) 
    // priceTP4 := tradeSide == "LONG" ?  tradeEntryPrice* (1 + tp4_percent) : tradeEntryPrice* (1 - tp4_percent)


    // Создаем линии 
    if show_tp_enty_sl
        lineTrail := trailWithPercent ? line.new(x1=startBarIndex, y1=tradeTrailPrice, x2=bar_index, y2=tradeTrailPrice, color=color.blue, style = line.style_dotted, width = 2) : na
        lineSL := line.new(x1=startBarIndex, y1=tradeSL, x2=bar_index, y2=tradeSL, color=color.red, style = line.style_dotted, width = 2)
        lineTP1 := line.new(x1=startBarIndex, y1=tradeTP1Limit, x2=bar_index, y2=tradeTP1Limit, color=color.green, style = line.style_dotted, width = 2)
        lineEntry  := line.new(x1=startBarIndex, y1=tradeEntryPrice, x2=bar_index, y2=tradeEntryPrice, color=color.gray, style = line.style_solid, width = 1)
        if not onceTP
            lineTP2 := line.new(x1=startBarIndex, y1=tradeTP2Limit, x2=bar_index, y2=tradeTP2Limit, color=color.green, style = line.style_dotted, width = 2)
            lineTP3 := line.new(x1=startBarIndex, y1=tradeTP3Limit, x2=bar_index, y2=tradeTP3Limit, color=color.green, style = line.style_dotted, width = 2)
            // lineTP4 := line.new(x1=startBarIndex, y1=priceTP4, x2=bar_index, y2=priceTP4, color=color.green, style = line.style_dotted, width = 2)

// Заливка
if canFill
    // Рассчет тейков
    hitTP1 := hitTP1 ? true : (tradeSide == "LONG" ? high >= tradeTP1Limit : low <= tradeTP1Limit)
    hitTP2 := hitTP2 ? true : (tradeSide == "LONG" ? high >= tradeTP2Limit : low <= tradeTP2Limit)
    hitTP3 := hitTP3 ? true : (tradeSide == "LONG" ? high >= tradeTP3Limit : low <= tradeTP3Limit)
    hitSL  := hitSL  ? true : (tradeSide == "LONG" ? low <= tradeSL : high >= tradeSL)

    if fill_positions
        if hitTP1
            linefill.new(lineEntry, lineTP1, color = color.new(color.green, 85))
        if hitTP2
            linefill.new(lineTP1, lineTP2, color = color.new(color.green, 85))
        if hitTP3
            linefill.new(lineTP2, lineTP3, color = color.new(color.green, 85))
        // if hitTP4
        //     linefill.new(lineTP3, lineTP4, color = color.new(color.green, 85))
        if hitSL
            linefill.new(lineSL, lineEntry, color = color.new(color.red, 85))

    if strategy.opentrades == 0
        canFill := false
        hitTP1 := false
        hitTP2 := false
        hitTP3 := false
        // hitTP4 := false
        hitSL  := false

// Продолжаем рисовать
if strategy.opentrades > 0 or (corShiftMode == "Don't move TP/SL" and corShiftWait)
    // Entry
    line.set_xy1(lineEntry, startBarIndex, tradeEntryPrice)
    line.set_xy2(lineEntry, bar_index + 1, tradeEntryPrice)
    // Trail    
    line.set_xy1(lineTrail, startBarIndex, tradeTrailPrice)
    line.set_xy2(lineTrail, bar_index + 1, tradeTrailPrice)
    // SL
    line.set_xy1(lineSL, startBarIndex, tradeSL)
    line.set_xy2(lineSL, bar_index + 1, tradeSL)
    // Cor
    line.set_xy1(lineCor, startBarIndexCor, priceCor)
    line.set_xy2(lineCor, bar_index + 1, priceCor)
    // TP1
    line.set_xy1(lineTP1, startBarIndex, tradeTP1Limit)
    line.set_xy2(lineTP1, bar_index + 1, tradeTP1Limit)
    // TP2
    line.set_xy1(lineTP2, startBarIndex, tradeTP2Limit)
    line.set_xy2(lineTP2, bar_index + 1, tradeTP2Limit)
    // TP3
    line.set_xy1(lineTP3, startBarIndex, tradeTP3Limit)
    line.set_xy2(lineTP3, bar_index + 1, tradeTP3Limit)
    // TP4
    // line.set_xy1(lineTP4, startBarIndex, priceTP4)
    // line.set_xy2(lineTP4, bar_index + 1, priceTP4)

    canFill := true



// can_long or  or can_short
// if ( (can_long and longRSI and longEMA) or (can_short and shortRSI and shortEMA) ) and na(trade) and canSignal ) or (useCorShift and canDraw)
if canDraw
    canDraw := false
    first_trade_date := trade_count == 0 ? timestamp(year, month, dayofmonth, hour, minute) : first_trade_date
    trade := Trade.new()
    // trade.side := can_long ? "LONG" : "SHORT"
    trade.side := tradeSide
    trade.entry_price := tradeEntryPrice
    trade.entry_hit := true
    trade.sl_price := math.round_to_mintick(tradeSide == "LONG" ? fixed_stop ? trade.entry_price * (1 - sl_percent) : fib_786 * (1 - sl_percent) : fixed_stop ? trade.entry_price * (1 + sl_percent) : fib_236 * (1 + sl_percent))
    trade.tp1_price := math.round_to_mintick(tradeSide == "LONG" ? trade.entry_price * (1 + tp1_percent) : trade.entry_price * (1 - tp1_percent))
    trade.tp1_percent_fix := tp1_percent_fix * 100
    trade.tp2_price := math.round_to_mintick(tradeSide == "LONG" ? trade.entry_price * (1 + tp2_percent) : trade.entry_price * (1 - tp2_percent))
    trade.tp2_percent_fix := tp2_percent_fix * 100
    trade.tp3_price := math.round_to_mintick(tradeSide == "LONG" ? trade.entry_price * (1 + tp3_percent) : trade.entry_price * (1 - tp3_percent))
    trade.tp3_percent_fix := tp3_percent_fix * 100
    trade.tp4_price := math.round_to_mintick(tradeSide == "LONG" ? trade.entry_price * (1 + tp4_percent) : trade.entry_price * (1 - tp4_percent))
    trade.tp4_percent_fix := tp4_percent_fix * 100
    trade.break_even_price := switch break_even_target
        "1" => trade.tp1_price
        "2" => trade.tp2_price
        "3" => trade.tp3_price
        "WITHOUT" => trade.tp4_price
    trade.risk_percent := risk_percent
    trade.risk_reward := calc_rr(trade.entry_price, trade.sl_price, trade.tp4_price)
    trade.start_bar_index := bar_index
    alert_message = "\n{\n" +  "    \"side\": \"" + str.tostring(trade.side) + "\",\n    \"entry\": \"" + str.tostring(trade.entry_price) + "\",\n    \"tp1\": \"" + str.tostring(trade.tp1_price) + "\",\n    \"tp2\": \"" + str.tostring(trade.tp2_price) + "\",\n    \"tp3\": \"" + str.tostring(trade.tp3_price) + "\",\n    \"tp4\": \"" + str.tostring(trade.tp4_price) + "\",\n    \"winrate\": \"" + str.tostring(RoundUp(profit_trades / trade_count * 100, 2)) + "%" + "\",\n    \"strategy\": \"" + strategy_input + "\",\n    \"beTargetTrigger\": \"" + break_even_target + "\",\n    \"stop\": \"" + str.tostring(trade.sl_price) + "\"\n}\n"
    alert(alert_message, alert.freq_once_per_bar_close)
    if show_tp_enty_sl
        entry_line  := line.new(x1=trade.start_bar_index, y1=trade.entry_price, x2=bar_index, y2=trade.entry_price, color=entry_color, style = line.style_solid, width = 2)
        entry_label := label.new(bar_index, trade.entry_price, str.tostring(trade.entry_price), style = label.style_label_left, color = color.rgb(255, 255, 255, 100), textcolor = color.gray)
        sl_line     := line.new(x1=trade.start_bar_index, y1=trade.sl_price, x2=bar_index, y2=trade.sl_price, color=sl_color, style = line_style, width = 2)
        sl_label := label.new(bar_index, trade.sl_price, str.tostring(trade.sl_price), style = label.style_label_left, color = color.rgb(255, 255, 255, 100), textcolor = color.red)
        tp1_line    := line.new(x1=trade.start_bar_index, y1=trade.tp1_price, x2=bar_index, y2=trade.tp1_price, color=tp_color, style = line_style, width = 2)
        tp1_label := label.new(bar_index, trade.tp1_price, str.tostring(trade.tp1_price), style = label.style_label_left, color = color.rgb(255, 255, 255, 100), textcolor = color.green)
        if not onceTP 
            tp2_line    := line.new(x1=trade.start_bar_index, y1=trade.tp2_price, x2=bar_index, y2=trade.tp2_price, color=tp_color, style = line_style, width = 2)
            tp2_label := label.new(bar_index, trade.tp2_price, str.tostring(trade.tp2_price), style = label.style_label_left, color = color.rgb(255, 255, 255, 100), textcolor = color.green)
            tp3_line    := line.new(x1=trade.start_bar_index, y1=trade.tp3_price, x2=bar_index, y2=trade.tp3_price, color=tp_color, style = line_style, width = 2)
            tp3_label := label.new(bar_index, trade.tp3_price, str.tostring(trade.tp3_price), style = label.style_label_left, color = color.rgb(255, 255, 255, 100), textcolor = color.green)
            tp4_line    := line.new(x1=trade.start_bar_index, y1=trade.tp4_price, x2=bar_index, y2=trade.tp4_price, color=tp_color, style = line_style, width = 2)
            tp4_label := label.new(bar_index, trade.tp4_price, str.tostring(trade.tp4_price), style = label.style_label_left, color = color.rgb(255, 255, 255, 100), textcolor = color.green)
        // lable_at_signal := label.new(bar_index, is_long_trend ? trade.tp4_price * 1.004 : trade.tp4_price * 0.996, "", style = label.style_label_center, textcolor = color.white)
    // For long   
    // if ta.crossunder(trade.break_even_price, lastPrice)
    //     strategy.close("Enter Long")
    // For short
    // if ta.crossover(trade.entry_price, trade.break_even_price)
    //     strategy.close("Enter Short")

//------------------------------------------------------RSI------------------------------------------------------------\\
rsi_value = ta.rsi(close, len)
is_overbought = rsi_value >= overbought
is_oversold = rsi_value <= oversold
// plotshape(is_overbought and show_rsi ? high : na, color=color.red, style=shape.cross, size=size.tiny, location=location.abovebar)
// plotshape(is_oversold and show_rsi ? low : na, color=color.green, style=shape.cross, size=size.tiny, location=location.belowbar)

//-----------------------------------------------------PANELS------------------------------------------------------------\\
lim = "-------------------------------------------------------"
high_idk = "╔════════════════════════════╗"
low_idk = "╚════════════════════════════╝"
panel_str1 = high_idk + "\n" + "ChiefDragon v1.9.1-Stable" + "\n" + low_idk
panel_str13 = "First signal: " + str.format("{0,date,hh:mm} {0,date,long}", first_trade_date) + "\n" + lim
panel_str14 = "Signal closed: " + str.tostring(trade_count) + "                 " + "Winrate: " + str.tostring(RoundUp(profit_trades / trade_count * 100, 2)) + "%"
panel_str15 = "Profit signals: " + str.tostring(profit_trades) + "              " + "Loss signals: " + str.tostring(trade_count - profit_trades)
panel_str16 = "Win streak: " + str.tostring(win_streak) + "                  " + "Loss streak: " + str.tostring(loss_streak) + "\n" + lim
panel_str17 = "💰 Profit: " + str.tostring(total_profit, "#.##") + "% 💰"
panel_last = "╚════════════════════════════╝" 
panel_str_arr = array.from(panel_str1, panel_str13, panel_str14, panel_str15, panel_str16, panel_str17, panel_last)
if show_old_panel
    label l = label.new(bar_index + 20, close, text=array.join(panel_str_arr, "\n"), color=color.rgb(0, 0, 0, 87), style=label.style_label_left, textcolor=color.rgb(76, 187, 72),textalign=text.align_center)
    label.delete(l[1])

var table profit_table = na
if show_profit_panel
    profit_table := table.new(position.top_right, 3, 10, border_color = color.green, border_width = 0)
    table.cell(profit_table, 0, 0, "═════════════════════════════" + "\n" + "ChiefDragon v1.9.1-Stable" + "\n" + "═════════════════════════════", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 6, height = 5, text_size = size.normal)
    table.cell(profit_table, 1, 0, "", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 6, height = 3, text_size = size.normal)
    table.merge_cells(profit_table, 0,0,1,0)
    table.cell(profit_table, 0, 1, "First trade:", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 8, height = 3, text_size = size.normal, text_halign = text.align_left)
    table.cell(profit_table, 1, 1, str.format("{0,date,long}", first_trade_date), bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 8, height = 3, text_size = size.normal)
    table.cell(profit_table, 0, 2, "Total trades:", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal, text_halign = text.align_left)
    table.cell(profit_table, 1, 2, str.tostring(trade_count), bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal)
    table.cell(profit_table, 0, 3, "Profit trades:", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal, text_halign = text.align_left)
    table.cell(profit_table, 1, 3, str.tostring(profit_trades), bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal)
    table.cell(profit_table, 0, 4, "Loss trades:", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal, text_halign = text.align_left)
    table.cell(profit_table, 1, 4, str.tostring(loss_trades), bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal)
    table.cell(profit_table, 0, 5, "Winrate:", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal, text_halign = text.align_left)
    table.cell(profit_table, 1, 5, str.tostring(RoundUp(profit_trades / trade_count * 100, 2)) + "%", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal)
    table.cell(profit_table, 0, 6, "Win streak:", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal, text_halign = text.align_left)
    table.cell(profit_table, 1, 6, str.tostring(win_streak), bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal)
    table.cell(profit_table, 0, 7, "Loss streak:", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal, text_halign = text.align_left)
    table.cell(profit_table, 1, 7, str.tostring(loss_streak), bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal)
    table.cell(profit_table, 0, 8, "Deposit: ", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal, text_halign = text.align_left)
    table.cell(profit_table, 1, 8, str.tostring(dep, "##.##"), bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal)
    table.cell(profit_table, 0, 9, "═════════════════════════════" + "\n" + "💰 Profit: " + str.tostring(total_profit, "#.##") + "% 💰" + "\n" + "═════════════════════════════", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 10, text_size = size.normal, text_halign = text.align_center, text_valign = text.align_top)
    table.cell(profit_table, 1, 9,"", bgcolor = color.rgb(0, 0, 0, 87), text_color = color.green, width = 5, height = 3, text_size = size.normal)
    table.merge_cells(profit_table, 0, 9, 1, 9)

