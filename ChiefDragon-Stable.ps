TFRSI = "1"

// MAX DEPOLOSS,DRAWDOWN & PROFIT
useMaxRowLoss = input.bool(defval = false, title = "Stop on max loss trades in a row", group = "STOP ON LOSS", tooltip = "en: Stops trading with alert (Then, you should to restart strategy manually). You should to set calculating time to the current before starting real-time trading (to avoid strategy blocking)\n\nru: Останавливает торговлю и отправляет сообщение (alert) (после, необходимо перезапустить стратегию вручную). Вам следует установить рассчетное время на текущее перед тем, как начинать торговлю в реальном времени (чтобы избежать блокировки работы стратегии)")
