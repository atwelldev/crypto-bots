trailTP = input.int(title="TP-num for trailing", options = [1, 2], defval = 1, group = STOP_LOSS, tooltip = "en: Number of takeprofit that launches trailing\n\nru: Номер тейка, запускающий трейлинг")
trailWithPercent = input.bool(title = "Trail after % of price", defval = false, group = STOP_LOSS, tooltip = "en: Trail will only start with % of price. 'TP-num for trailing' will not affect\n\nru: Трейл запускается от % от изначальной цены, 'TP-num for trailing' не возымеет эффекта")
trailStartPercent = input.float(title="% for trail start", step = 0.05, defval=0.5, minval = 0.00001, group = STOP_LOSS)
trailStartPercent /= 100
atrAutoActive = input.bool(title = "Use auto TP/SL/Trail by ATR", group = STOP_LOSS, defval = false)
atrLength = input.int(defval = 14, step = 1, title='ATR length (bars)', group = STOP_LOSS)
atrMultTP = input.float(defval = 2.0, step = 0.1, title='Multiplier for TP', group = STOP_LOSS)
atrMultTrail = input.float(defval = 1.0, step = 0.1, title='Multiplier for Trail', group = STOP_LOSS)
atrMultSL = input.float(defval = 1.0, step = 0.1, title='Multiplier for SL', group = STOP_LOSS)


// Correction shift
useCorShift = input.bool(defval = false, title = "Use corrective shift", group = "CORRECTIVE SHIFT", tooltip = "en: To open positions after correction. The strategy waits for the price to cross the entry price (by signal) by the specified percentage then opens position. Waiting for correction ends if a new signal is received or the price has crossed the 1 TP level.\n\nru: Открывать позицию после коррекции. Стратегия ждет, когда цена пересечет изначальную цену входа (от сигнала) на указанный %, затем открывает позицию. Ожидание коррекции прекращается, если был получен новый сигнал или цена пересекла уровень 1-TP")
corShiftMode = input.string(title = "Move or not TP/SL", defval = "Move TP/SL", options = ["Move TP/SL", "Don't move TP/SL"], group = "CORRECTIVE SHIFT", tooltip = "en: Move or not TP/SL levels after entry. If 'Don't move TP/SL' is chosen, doesn't open positions in case that current price is crossing SL while waiting for correction\n\nru: Перемещать или нет уровни TP/SL. Если режим 'Don't move TP/SL' выбран, не открывает позицию, если цена пересекает уровень SL при ожидании коррекции")
corShiftSize = input.float(defval = 0.01, title = "Corrective  shift size (%)", group = "CORRECTIVE SHIFT", step = 0.05, minval = 0)
corShiftSize /= 100
useCorShiftAuto = input.bool(defval = false, title = "Auto corrective shift size", group = "CORRECTIVE SHIFT", tooltip = "en: Correction size will be calculated automatically by Fibonacci zones.\n\nru: Величина коррекции будет рассчитана автоматически по зонам Фибоначчи")  
// corShiftAutoFibo = input.string(defval = "AlgoFibo: 0.236-0.786", options = ["AlgoFibo: 0.236-0.786", "AlgoFibo: 0.296-0.704", "AlgoFibo: 0.386-0.618"],  title = "Fibo zones for auto cor. size", group = "CORRECTIVE SHIFT")
sensitivity_input = input.float(title = 'Fibo length for auto (bars)', step = 1, defval = 12, group = "CORRECTIVE SHIFT", tooltip = "en: Amount of bars for Fibonacci channel length. Needed to calculate auto-correction size\n\nru: Кол-во баров для длины канала Фибоначчи. Нужно для рассчета размера авто-коррекции")
useCorShiftBars = input.bool(defval = false, title = "Use limit of bars", group = "CORRECTIVE SHIFT", tooltip = "en: Don't open the position after a certain amount of bars\n\nru: Не открывать позицию после определенного кол-ва баров")  
corShiftBars = input.int(defval = 1, title = "Amount of bars", group = "CORRECTIVE SHIFT", step = 1, minval = 1)

// VOLUMES
useVolAnomaly = input.bool(defval = false, title='Use volume filter: "Anomaly"', group = "VOLUMES")
volAnomalyReverse = input.bool(defval = false, title='Reverse volume "Anomaly"', group = "VOLUMES", tooltip = "Если включено: вход если объем больше предыдущего, (если отключено, но вход если объем меньше предыдущего")
