// StopTPNum

//alertcondition(can_long and na(trade), "Long signal", "Long") - для лонга
//alertcondition(can_short and na(trade), "Short signal", "Short") - для шорта
//alertcondition(can_short or can_long and na(trade), "New signal", "Check chart to see signal direction")
