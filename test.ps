varip strDirection = ""
strDirection := posMode


//-----------------------------------------------GLOBAL VARIABLES------------------------------------------------------\\
var float total_profit = 0.0
var int trade_count = 0
var int profit_trades = 0
var int loss_trades = 0
var int loss_streak = 0
var int loss_in_a_row = 0
var int win_streak = 0
var int wins_in_a_row = 0
var int first_trade_date = na
var Trade trade = na
var bool is_long_trend_started = false
var bool is_short_trend_started = false
var bool is_trend_change = na
var bool is_long_trend = false
var bool is_short_trend = false
var bool can_long = false
var bool can_short = false

var int trend_started_bar_index = na
var line tp1_line = na
var label tp1_label = na
var line tp2_line = na
var label tp2_label = na
var line tp3_line = na
var label tp3_label = na
var line tp4_line = na
var label tp4_label = na
var line entry_line = na
var label entry_label = na
var line close_line = na
var line sl_line = na
var label sl_label = na
var label lable_at_signal = na
var int signal_closed_bar = na
var Strategy_settings strategy_s = na
var float dep = initial_deposit_input



//-----------------------------------------------------MAIN------------------------------------------------------------\\
// STRATEGY

strategy_s := strategy_input == "MANUAL" ? Strategy_settings.new(sensitivity_input, risk_percent_input, break_even_target_input, tp1_percent_input, tp1_percent_fix_input, tp2_percent_input, tp2_percent_fix_input, tp3_percent_input, tp3_percent_fix_input, tp4_percent_input, tp4_percent_fix_input, fixed_stop_input, sl_percent_input, trailPercent_input) : selector(strategy_input)

sensitivity := strategy_s.sensitivity
risk_percent := strategy_s.risk_percent
break_even_target := strategy_s.break_even_target
tp1_percent := strategy_s.tp1_percent
tp1_percent_fix := strategy_s.tp1_percent_fix
tp2_percent := strategy_s.tp2_percent
tp2_percent_fix := strategy_s.tp2_percent_fix
tp3_percent := strategy_s.tp3_percent
tp3_percent_fix := strategy_s.tp3_percent_fix
tp4_percent := strategy_s.tp4_percent
tp4_percent_fix := strategy_s.tp4_percent_fix
fixed_stop := strategy_s.fixed_stop
sl_percent := strategy_s.sl_percent
trailPercent := strategy_s.trailPercent


// sensitivity *= 10
tp1_percent /= 100
tp2_percent /= 100
tp3_percent /= 100
tp4_percent /= 100
tp1_percent_fix /= 100
tp2_percent_fix /= 100
tp3_percent_fix /= 100
tp4_percent_fix /= 100
sl_percent /= 100


high_line = ta.highest(high, int(sensitivity))
low_line = ta.lowest(low, int(sensitivity))
channel_range = high_line - low_line
fib_236 = high_line - channel_range * (0.236)
fib_382 = high_line - channel_range * 0.382
fib_5 = high_line - channel_range * 0.5
fib_618 = high_line - channel_range * 0.618
fib_786 = high_line - channel_range * (0.786)
imba_trend_line = fib_5




varip float tradeEntryPrice = 0
varip string tradeSide = ""
varip bool canSignal = true
varip int trailOffset = 0 
varip float trailPrice = 0
varip bool corShiftLong = false
varip bool corShiftShort = false
varip bool corShiftWait = false
varip bool canDraw = false


// CAN LONG/SHORT
if time < start_date_input
    canSignal := false


if strategy.opentrades > 0
    canSignal := true
else 
    strategy.cancel_all()
    canSignal := true


// Corrective shift
// fib_382 = high_line - channel_range * 0.382
// fib_5 = high_line - channel_range * 0.5
// fib_618 = high_line - channel_range * 0.618

varip bool canDrawCor = false
var int corStartBar = 0
barIndex = bar_index

var bool corBarPassed = false
corBarPassed := corStartBar != 0 and (barIndex - corStartBar >= corShiftBars)

if useCorShift and corShiftWait and tradeSide == "LONG" and close <= (useCorShiftAuto ? fib_382 : tradeEntryPrice * (1- corShiftSize) ) and (close >= tradeEntryPrice* (1 - sl_percent) or corShiftMode == "Move TP/SL")
    corShiftLong := true
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "LONG" and close <= tradeEntryPrice* (1 - sl_percent)  and corShiftMode == "Don't move TP/SL"
    corShiftLong := false
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "LONG" and close >= tradeEntryPrice * (1+ tp1_percent) 
    corShiftLong := false
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "LONG" and useCorShiftBars and corBarPassed 
    corShiftLong := false
    corShiftWait := false
    canDrawCor := false


if useCorShift and corShiftWait and tradeSide == "SHORT" and close >= (useCorShiftAuto ? fib_618 : tradeEntryPrice * (1+ corShiftSize)) and (close <= tradeEntryPrice* (1 + sl_percent) or corShiftMode == "Move TP/SL")
    corShiftShort := true
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "SHORT" and close >= tradeEntryPrice* (1+ sl_percent) and corShiftMode == "Don't move TP/SL"
    corShiftShort := false
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "SHORT" and close <= tradeEntryPrice * (1- tp1_percent) 
    corShiftShort := false
    corShiftWait := false
    canDrawCor := false
if useCorShift and corShiftWait and tradeSide == "SHORT" and useCorShiftBars and corBarPassed
    corShiftLong := false
    corShiftWait := false
    canDrawCor := false

// plot(canSignal ? 1 : 0)
// plot(corShiftLong ? 1 : 0)
// plot(corShiftShort ? 1 : 0)

// Volume calculating
var bool volAnomaly = false

var bool volVWAPLong = false 
var bool volVWAPShort = false

// var bool volOBVLong = false
// var bool volOBVShort = false
    // Anomaly
if useVolAnomaly and volAnomalyReverse == false 
    averageVolume = ta.sma(volume, volAnomalySMALen)
    volAnomaly := volume < (averageVolume*volAnomalyMult)
else if useVolAnomaly and volAnomalyReverse
    averageVolume = ta.sma(volume, volAnomalySMALen)
    volAnomaly := volume > (averageVolume*volAnomalyMult)

    // OBV
// if useVolOBV
//     obvValue = ta.obv
//     volOBVShort := ta.falling(obvValue, volOBVLen) and ta.rising(close, volOBVLen)
//     volOBVLong := ta.rising(obvValue, volOBVLen) and ta.falling(close, volOBVLen)

    // VWAP
if useVolVWAP
    vwapValue = ta.vwap(close)
    volVWAPLong := ta.crossover(close, vwapValue)  // Покупка при пробое VWAP снизу вверх
    volVWAPShort := ta.crossunder(close, vwapValue)  // Продажа при пробое VWAP сверху вниз

// Max profit and drawdown
var int rowLossCount = 0

if strategy.losstrades > strategy.losstrades[1]
    rowLossCount += 1

if strategy.wintrades > strategy.wintrades[1]
    rowLossCount := 0

if useMaxRowLoss and rowLossCount == maxRowLoss
    canSignal := false
    alert("Max number of loss trades in a row is detected! Please, restart the strategy")    

var float atrVal = 0
var float tradeTP1Limit = 0
var float tradeTP2Limit = 0
var float tradeTP3Limit = 0
var float tradeTP4Limit = 0
var float tradeTP1Size = 0
var float tradeTP2Size = 0
var float tradeTP3Size = 0
var float tradeTP4Size = 0
var float tradeSL = 0
var float tradeTrailPrice = 0
// ATR
if atrAutoActive
    atrVal := ta.atr(atrLength)




// Entries
if (buy and strDirection != "only short") or (tradeSide == "LONG" and corShiftLong and corShiftShort == false)
    tradeSide := "LONG"
    canDrawCor := false
    
    if useCorShift and corShiftLong == false
        tradeEntryPrice := close
        if corShiftMode == "Don't move TP/SL"
            tradeTP1Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP) : tradeEntryPrice* (1 - tp1_percent)
            tradeTP1Size := tp1_percent_fix * 100
            tradeTP2Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP * 2) : tradeEntryPrice* (1 - tp2_percent)
            tradeTP2Size := tp2_percent_fix * 100
            tradeTP3Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP * 3) : tradeEntryPrice* (1 - tp3_percent)
            tradeTP3Size := tp3_percent_fix * 100
            tradeSL := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultSL) : tradeEntryPrice* (1 + sl_percent)
            trailOffset := int((close * (trailPercent / 100)) / syminfo.mintick)
            canDraw := true
        corShiftWait := true
        corShiftShort := false
        corStartBar := bar_index

    else if corShiftLong or useCorShift == false
        strategy.close("Enter Short")
        strategy.entry("Enter Long", strategy.long)

        if useCorShift == false or (useCorShift and corShiftMode == "Move TP/SL")
            canDraw := true
            tradeEntryPrice := close
        
        corShiftLong := false
        canSignal := false
        // tradeEntryPrice := close
        tradeTP1Limit := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultTP) : tradeEntryPrice* (1 + tp1_percent)
        tradeTP1Size := tp1_percent_fix * 100
        tradeTP2Limit := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultTP * 2) : tradeEntryPrice* (1 + tp2_percent)
        tradeTP2Size := tp2_percent_fix * 100
        tradeTP3Limit := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultTP * 3) : tradeEntryPrice* (1 + tp3_percent)
        tradeTP3Size := tp3_percent_fix * 100
        tradeSL := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultSL) : tradeEntryPrice* (1 - sl_percent)
        trailOffset := int((close * (trailPercent / 100)) / syminfo.mintick)
        if trailWithPercent == true
            tradeTrailPrice := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultTrail) : tradeEntryPrice* (1 + trailStartPercent)
        else 
            if trailTP == 0
                tradeTrailPrice := 0
            else if trailTP == 1
                tradeTrailPrice := tradeTP1Limit
            else if trailTP == 2
                tradeTrailPrice := tradeTP2Limit
            // else if trailTP == 3
            //     trailPrice := tradeEntryPrice* (1 + tp3_percent)
        // once TP
        if onceTP 
            strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Long: trail", comment_profit = "Long: TP-1", comment_loss = "Long: stoploss")
        else 
            // Проверка на 0 ордера
            if tp1_percent_fix != 0 and (tp2_percent_fix != 0 or tp3_percent_fix != 0 or tp4_percent_fix != 0) 
                strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP1Size, comment_trailing = "Long: trail", comment_profit = "Long: TP-1", comment_loss = "Long: stoploss")
            else if tp1_percent_fix != 0 and (tp2_percent_fix == 0 and tp3_percent_fix == 0 and tp4_percent_fix == 0)
                strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Long: trail", comment_profit = "Long: TP-1", comment_loss = "Long: stoploss")
            
            if tp2_percent_fix != 0 and (tp3_percent_fix != 0 or tp4_percent_fix != 0)
                strategy.exit("Long TP-2/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP2Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP2Size, comment_trailing = "Long: trail", comment_profit = "Long: TP-2", comment_loss = "Long: stoploss")
            else if tp2_percent_fix != 0 and (tp3_percent_fix == 0 and tp4_percent_fix == 0)
                strategy.exit("Long TP-2/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP2Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Long: trail", comment_profit = "Long: TP-2", comment_loss = "Long: stoploss")
            
            if tp3_percent_fix != 0 and tp4_percent_fix != 0
                strategy.exit("Long TP-3/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP3Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP3Size, comment_trailing = "Long: trail", comment_profit = "Long: TP-3", comment_loss = "Long: stoploss")
            else if tp3_percent_fix != 0 and tp4_percent_fix == 0
                strategy.exit("Long TP-3/Trail/SL", from_entry="Enter Long", stop = tradeSL, limit=tradeTP3Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Long: trail", comment_profit = "Long: TP-3", comment_loss = "Long: stoploss")
            
            // if tp4_percent_fix != 0
            //     strategy.exit("Long TP-4/Trail/SL", from_entry="Enter Long", stop = fixed_stop ? tradeEntryPrice* (1 - sl_percent) : fib_786, limit=tradeEntryPrice* (1 + tp4_percent), trail_price = trailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Long: trail", comment_profit = "Long: TP-4", comment_loss = "Long: stoploss" )

if (sell and strDirection != "only long") or (tradeSide == "SHORT" and corShiftShort and corShiftLong == false)
    tradeSide := "SHORT"
    canDrawCor := false
    if useCorShift and corShiftShort == false
        tradeEntryPrice := close
        if corShiftMode == "Don't move TP/SL"
            tradeTP1Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP) : tradeEntryPrice* (1 - tp1_percent)
            tradeTP1Size := tp1_percent_fix * 100
            tradeTP2Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP * 2) : tradeEntryPrice* (1 - tp2_percent)
            tradeTP2Size := tp2_percent_fix * 100
            tradeTP3Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP * 3) : tradeEntryPrice* (1 - tp3_percent)
            tradeTP3Size := tp3_percent_fix * 100
            tradeSL := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultSL) : tradeEntryPrice* (1 + sl_percent)
            trailOffset := int((close * (trailPercent / 100)) / syminfo.mintick)
            canDraw := true
        corShiftWait := true
        corShiftLong := false
        corStartBar := bar_index
    
    else if corShiftShort or useCorShift == false
        strategy.close("Enter Long")
        strategy.entry("Enter Short", strategy.short)

        if useCorShift == false or (useCorShift and corShiftMode == "Move TP/SL")
            canDraw := true
            tradeEntryPrice := close

        corShiftShort := false
        canSignal := false
        // tradeEntryPrice := close
        tradeTP1Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP) : tradeEntryPrice* (1 - tp1_percent)
        tradeTP1Size := tp1_percent_fix * 100
        tradeTP2Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP * 2) : tradeEntryPrice* (1 - tp2_percent)
        tradeTP2Size := tp2_percent_fix * 100
        tradeTP3Limit := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTP * 3) : tradeEntryPrice* (1 - tp3_percent)
        tradeTP3Size := tp3_percent_fix * 100
        tradeSL := atrAutoActive ? tradeEntryPrice + (atrVal * atrMultSL) : tradeEntryPrice* (1 + sl_percent)
        trailOffset := int((close * (trailPercent / 100)) / syminfo.mintick)
        if trailWithPercent == true
            tradeTrailPrice := atrAutoActive ? tradeEntryPrice - (atrVal * atrMultTrail) : tradeEntryPrice* (1 - trailStartPercent)
        else 
            if trailTP == 0
                tradeTrailPrice := 0
            else if trailTP == 1
                tradeTrailPrice := tradeTP1Limit
            else if trailTP == 2
                tradeTrailPrice := tradeTP2Limit
            // else if trailTP == 3
            //     trailPrice := tradeEntryPrice* (1 + tp3_percent)
        // once TP
        if onceTP 
            strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Short: trail", comment_profit = "Short: TP-1", comment_loss = "Short: stoploss")
        else 
            // Проверка на 0 ордера
            if tp1_percent_fix != 0 and (tp2_percent_fix != 0 or tp3_percent_fix != 0 or tp4_percent_fix != 0) 
                strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP1Size, comment_trailing = "Short: trail", comment_profit = "Short: TP-1", comment_loss = "Short: stoploss")
            else if tp1_percent_fix != 0 and (tp2_percent_fix == 0 and tp3_percent_fix == 0 and tp4_percent_fix == 0)
                strategy.exit("Long TP-1/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP1Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Short: trail", comment_profit = "Short: TP-1", comment_loss = "Short: stoploss")
            
            if tp2_percent_fix != 0 and (tp3_percent_fix != 0 or tp4_percent_fix != 0)
                strategy.exit("Long TP-2/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP2Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP2Size, comment_trailing = "Short: trail", comment_profit = "Short: TP-2", comment_loss = "Short: stoploss")
            else if tp2_percent_fix != 0 and (tp3_percent_fix == 0 and tp4_percent_fix == 0)
                strategy.exit("Long TP-2/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP2Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Short: trail", comment_profit = "Short: TP-2", comment_loss = "Short: stoploss")
            
            if tp3_percent_fix != 0 and tp4_percent_fix != 0
                strategy.exit("Long TP-3/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP3Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=tradeTP3Size, comment_trailing = "Short: trail", comment_profit = "Short: TP-3", comment_loss = "Short: stoploss")
            else if tp3_percent_fix != 0 and tp4_percent_fix == 0
                strategy.exit("Long TP-3/Trail/SL", from_entry="Enter Short", stop = tradeSL, limit=tradeTP3Limit, trail_price = tradeTrailPrice, trail_offset = trailOffset, qty_percent=100, comment_trailing = "Short: trail", comment_profit = "Short: TP-3", comment_loss = "Short: stoploss")
         
// Закомментировать
// plot(canSignal ? 1.0 : 0)
// plot(can_long ? 1.0 : 0)
// plot(na(trade) ? 1.0 : 0)
// plot(tradeEntryPrice)
// plot(math.ceil(trailOffset))


// New lines
var line lineTP1 = na
var line lineTP2 = na
var line lineTP3 = na
var line lineTP4 = na
var line lineSL = na
var line lineTrail = na
var line lineCor = na
var line lineEntry = na
var int startBarIndex = na
var int startBarIndexCor = na
var float priceTP1 = na
var float priceTP2 = na
var float priceTP3 = na
var float priceTP4 = na
var float priceSL = na
var float priceCor = na
varip bool hitTP1 = na
varip bool hitTP2 = na
varip bool hitTP3 = na
// varip bool hitTP4 = na
var bool hitSL = na
varip bool canFill = na
varip float cortradeEntryPrice = na

// Creating lines
if corShiftWait and canDrawCor != true and show_tp_enty_sl
    startBarIndexCor := bar_index
    cortradeEntryPrice := tradeEntryPrice
    priceCor := tradeSide == "LONG" ? (useCorShiftAuto ? fib_382 : cortradeEntryPrice * (1- corShiftSize)) : (useCorShiftAuto ? fib_618 : cortradeEntryPrice * (1+ corShiftSize))
    lineCor := useCorShift and useCorShiftAuto != true ? line.new(x1=startBarIndex, y1=priceCor, x2=bar_index, y2=priceCor, color=color.yellow, style = line.style_dotted, width = 2) : na
    canDrawCor := true

if corShiftWait and canDrawCor
    // Cor
    line.set_xy1(lineCor, startBarIndexCor, priceCor)
    line.set_xy2(lineCor, bar_index + 1, priceCor)


if canDraw
    canDraw := false
    startBarIndex := bar_index

    priceSL  := tradeSide == "LONG" ?  (fixed_stop ? tradeEntryPrice* (1 - sl_percent) : fib_786) : (fixed_stop ? tradeEntryPrice* (1 + sl_percent) : fib_236)
    priceTP1 := tradeSide == "LONG" ?  tradeEntryPrice* (1 + tp1_percent) : tradeEntryPrice* (1 - tp1_percent)
    priceTP2 := tradeSide == "LONG" ?  tradeEntryPrice* (1 + tp2_percent) : tradeEntryPrice* (1 - tp2_percent)
    priceTP3 := tradeSide == "LONG" ?  tradeEntryPrice* (1 + tp3_percent) : tradeEntryPrice* (1 - tp3_percent)
    trailPrice := tradeSide == "LONG" ? tradeEntryPrice* (1 + trailStartPercent) : tradeEntryPrice* (1 - trailStartPercent) 
    // priceTP4 := tradeSide == "LONG" ?  tradeEntryPrice* (1 + tp4_percent) : tradeEntryPrice* (1 - tp4_percent)


    // Создаем линии 
    if show_tp_enty_sl
        lineTrail := trailWithPercent ? line.new(x1=startBarIndex, y1=tradeTrailPrice, x2=bar_index, y2=tradeTrailPrice, color=color.blue, style = line.style_dotted, width = 2) : na
        lineSL := line.new(x1=startBarIndex, y1=tradeSL, x2=bar_index, y2=tradeSL, color=color.red, style = line.style_dotted, width = 2)
        lineTP1 := line.new(x1=startBarIndex, y1=tradeTP1Limit, x2=bar_index, y2=tradeTP1Limit, color=color.green, style = line.style_dotted, width = 2)
        lineEntry  := line.new(x1=startBarIndex, y1=tradeEntryPrice, x2=bar_index, y2=tradeEntryPrice, color=color.gray, style = line.style_solid, width = 1)
        if not onceTP
            lineTP2 := line.new(x1=startBarIndex, y1=tradeTP2Limit, x2=bar_index, y2=tradeTP2Limit, color=color.green, style = line.style_dotted, width = 2)
            lineTP3 := line.new(x1=startBarIndex, y1=tradeTP3Limit, x2=bar_index, y2=tradeTP3Limit, color=color.green, style = line.style_dotted, width = 2)
            // lineTP4 := line.new(x1=startBarIndex, y1=priceTP4, x2=bar_index, y2=priceTP4, color=color.green, style = line.style_dotted, width = 2)

// Заливка
if canFill
    // Рассчет тейков
    hitTP1 := hitTP1 ? true : (tradeSide == "LONG" ? high >= tradeTP1Limit : low <= tradeTP1Limit)
    hitTP2 := hitTP2 ? true : (tradeSide == "LONG" ? high >= tradeTP2Limit : low <= tradeTP2Limit)
    hitTP3 := hitTP3 ? true : (tradeSide == "LONG" ? high >= tradeTP3Limit : low <= tradeTP3Limit)
    hitSL  := hitSL  ? true : (tradeSide == "LONG" ? low <= tradeSL : high >= tradeSL)

    if fill_positions
        if hitTP1
            linefill.new(lineEntry, lineTP1, color = color.new(color.green, 85))
        if hitTP2
            linefill.new(lineTP1, lineTP2, color = color.new(color.green, 85))
        if hitTP3
            linefill.new(lineTP2, lineTP3, color = color.new(color.green, 85))
        // if hitTP4
        //     linefill.new(lineTP3, lineTP4, color = color.new(color.green, 85))
        if hitSL
            linefill.new(lineSL, lineEntry, color = color.new(color.red, 85))

    if strategy.opentrades == 0
        canFill := false
        hitTP1 := false
        hitTP2 := false
        hitTP3 := false
        // hitTP4 := false
        hitSL  := false

// Продолжаем рисовать
if strategy.opentrades > 0 or (corShiftMode == "Don't move TP/SL" and corShiftWait)
    // Entry
    line.set_xy1(lineEntry, startBarIndex, tradeEntryPrice)
    line.set_xy2(lineEntry, bar_index + 1, tradeEntryPrice)
    // Trail    
    line.set_xy1(lineTrail, startBarIndex, tradeTrailPrice)
    line.set_xy2(lineTrail, bar_index + 1, tradeTrailPrice)
    // SL
    line.set_xy1(lineSL, startBarIndex, tradeSL)
    line.set_xy2(lineSL, bar_index + 1, tradeSL)
    // Cor
    line.set_xy1(lineCor, startBarIndexCor, priceCor)
    line.set_xy2(lineCor, bar_index + 1, priceCor)
    // TP1
    line.set_xy1(lineTP1, startBarIndex, tradeTP1Limit)
    line.set_xy2(lineTP1, bar_index + 1, tradeTP1Limit)
    // TP2
    line.set_xy1(lineTP2, startBarIndex, tradeTP2Limit)
    line.set_xy2(lineTP2, bar_index + 1, tradeTP2Limit)
    // TP3
    line.set_xy1(lineTP3, startBarIndex, tradeTP3Limit)
    line.set_xy2(lineTP3, bar_index + 1, tradeTP3Limit)
    // TP4
    // line.set_xy1(lineTP4, startBarIndex, priceTP4)
    // line.set_xy2(lineTP4, bar_index + 1, priceTP4)

    canFill := true

